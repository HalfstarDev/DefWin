end

-- Set border color to default
function buttons.border_color_1()
	defwin.set_border_color()
end

-- Set border color to red
function buttons.border_color_2()
	defwin.set_border_color(1, 0, 0)
end

-- Set border color to green
function buttons.border_color_3()
	defwin.set_border_color(0, 1, 0)
