end

-- Set border color to transparent
function buttons.music_1()
	sound.stop("/example#music")
	sound.play("/example#music")
end

local function pick_option(id, option, n)
	for i = 1, n do
		local node = gui.get_node(id.."_"..i.."/picked")
		local to = i == option and 1 or 0
		gui.animate(node, "color.w", to, LINEAR, 0.15)
	end
	buttons[id.."_"..option]()
end

local function check_options(id, n, x, y)
	for i = 1, n do
		if gui.pick_node(gui.get_node(id.."_"..i.."/click"), x, y) then
			pick_option(id, i, n)
			return true
		end
	end
end

local function check_buttons(id, n, x, y)
	for i = 1, n do
		if gui.pick_node(gui.get_node(id.."_"..i), x, y) then
			buttons[id.."_"..i]()
			return true
		end
	end
end

local function check_slider(x, y, dx, sx, pressed)
	local node = gui.get_node("slider_handle")
	if pressed then
		slider_pressed = gui.pick_node(gui.get_node("slider_area"), x, y)
	end
	if slider_pressed then
		local min = gui.get_screen_position(gui.get_node("slider_min"))
		local max = gui.get_screen_position(gui.get_node("slider_max"))
		local screen_position = gui.get_screen_position(node)
		if sx < min.x then
			screen_position.x = min.x
		elseif sx > max.x then
			screen_position.x = max.x
		else
			screen_position.x = sx
		end
		gui.set_screen_position(node, screen_position)
		local value = (screen_position.x - min.x) / (max.x - min.x)
		local alpha = 0.2 + 0.8 * value
		defwin.set_alpha(alpha)
		return true
	end
end

function init(self)
	msg.post("@render:", "use_fixed_fit_projection", { near = -1, far = 1 })
	msg.post(".", "acquire_input_focus")
	pick_option("aspect_ratio", 1, 4)
	pick_option("close", 1, 4)
	local dark_mode_preference = defwin.get_dark_mode_preference()
	if dark_mode_preference ~= nil then
		apply_dark_mode(dark_mode_preference)
	end

	gui.set_color(gui.get_node("drag"), defwin.get_caption_color())
end

function on_input(self, action_id, action)
	if popup then
		if action_id == hash("touch") and action.pressed then
			if gui.pick_node(gui.get_node("popup"), action.x, action.y) then
				if gui.pick_node(gui.get_node("popup_yes"), action.x, action.y) then
					defwin.quit()
				elseif gui.pick_node(gui.get_node("popup_no"), action.x, action.y) then
					close_popup()
				end
			else
				close_popup()
			end
		end
		return
	end
	if action_id == hash("touch") then
		if check_slider(action.x, action.y, action.dx, action.screen_x, action.pressed) then return end
		if action.pressed then
			if check_options("aspect_ratio", 4, action.x, action.y) then return end
			if check_options("close", 4, action.x, action.y) then return end
			if check_buttons("flash", 2, action.x, action.y) then return end
			if check_buttons("transparency", 2, action.x, action.y) then return end
			if check_buttons("darkmode", 2, action.x, action.y) then return end
			if check_buttons("corner", 3, action.x, action.y) then return end
			if check_buttons("progress", 2, action.x, action.y) then return end
			if check_buttons("rtl", 2, action.x, action.y) then return end
			if check_buttons("caption_text_color", 4, action.x, action.y) then return end
			if check_buttons("caption_color", 4, action.x, action.y) then return end
			if check_buttons("border_color", 5, action.x, action.y) then return end
			if check_buttons("music", 1, action.x, action.y) then return end
			if gui.pick_node(gui.get_node("drag"), action.x, action.y) then
				defwin.start_drag()
			end
			if gui.pick_node(gui.get_node("close_button"), action.x, action.y) then
				defwin.request_quit()
			end
		end
		defwin.update_drag()
		if action.released then
			defwin.stop_drag()
		end
	elseif action_id == hash("space") and action.pressed then
		defwin.fit_screen()
	end
end
