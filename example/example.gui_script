end

-- Set caption color to red
function buttons.caption_color_4()
	defwin.set_caption_color(0, 0, 1)
end

-- Set caption text color to default
function buttons.caption_text_color_1()
	defwin.set_caption_text_color()
end

-- Set caption text color to red
function buttons.caption_text_color_2()
	defwin.set_caption_text_color(1, 0, 0)
end

-- Set caption text color to green
function buttons.caption_text_color_3()
	defwin.set_caption_text_color(0, 1, 0)
end

-- Set caption text color to blue
function buttons.caption_text_color_4()
